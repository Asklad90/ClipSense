{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["email", "createdAt"]
    },
    "Analysis": {
      "title": "Analysis",
      "description": "An analysis of a video containing transcript and highlights",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "videoName": { "type": "string" },
        "videoSize": { "type": "number" },
        "transcript": {
           "type": "array",
           "items": { "type": "object" }
        },
        "highlights": {
           "type": "array",
           "items": { "type": "object" }
        },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "videoName", "createdAt", "transcript", "highlights"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profile data"
    },
    "/users/{userId}/analyses/{analysisId}": {
      "schema": { "$ref": "#/entities/Analysis" },
      "description": "Video analyses for the user"
    }
  }
}
