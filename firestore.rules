rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'createdAt']) &&
             data.keys().size() == 2 &&
             data.email is string && data.email.size() <= 256 &&
             data.createdAt == request.time;
    }
    
    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId; // Basic profile retrieval
      allow create: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidUser(incoming());
      allow update, delete: if false; // No modifications supported yet

      function isValidAnalysis(data) {
        return data.keys().hasAll(['userId', 'videoName', 'createdAt', 'transcript', 'highlights']) &&
               (data.keys().size() == 5 || (data.keys().hasAll(['videoSize']) && data.keys().size() == 6)) &&
               data.userId == request.auth.uid &&
               data.videoName is string && data.videoName.size() <= 256 &&
               data.createdAt == request.time &&
               data.transcript is list && data.transcript.size() >= 0 && data.transcript.size() <= 10000 &&
               data.highlights is list && data.highlights.size() >= 0 && data.highlights.size() <= 1000;
      }

      match /analyses/{analysisId} {
        allow get: if isSignedIn() && request.auth.uid == userId;
        allow list: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidId(analysisId) && isValidAnalysis(incoming()) && exists(/databases/$(database)/documents/users/$(userId));
        allow update: if false;
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}
